{
    "openapi": "3.0.0",
    "info": {
        "title": "RZD API",
        "description": "API для получения информации о маршрутах поездов, вагонах и станциях.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://api.rzd.ru",
            "description": "Cервер РЖД"
        }
    ],
    "paths": {
        "/api/trainRoutes": {
            "get": {
                "tags": [
                    "RZD API"
                ],
                "summary": "Получение маршрутов в одну точку",
                "description": "Возвращает маршруты поездов из одной точки в другую.",
                "operationId": "6f6d686df3a092dbd2c508c9572640a9",
                "parameters": [
                    {
                        "name": "code0",
                        "in": "query",
                        "description": "Код станции отправления",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "code1",
                        "in": "query",
                        "description": "Код станции прибытия",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "dir",
                        "in": "query",
                        "description": "Направление (0 - в одну сторону, 1 - туда-обратно)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 0
                        }
                    },
                    {
                        "name": "tfl",
                        "in": "query",
                        "description": "Тип поезда (3 - поезда и электрички, 2 - электрички, 1 - поезда)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 3
                        }
                    },
                    {
                        "name": "checkSeats",
                        "in": "query",
                        "description": "Проверка наличия свободных мест (1 - с билетами, 0 - все поезда)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "dt0",
                        "in": "query",
                        "description": "Дата отправления в формате d.m.Y",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "default": ""
                        }
                    },
                    {
                        "name": "md",
                        "in": "query",
                        "description": "Маршруты с пересадками (1 - с пересадками, 0 - только прямые рейсы)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 0
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список маршрутов",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/TrainRoute"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Некорректные параметры запроса",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "error": {
                                            "type": "string",
                                            "example": "Некорректный код станции отправления"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/trainRoutesReturn": {
            "get": {
                "tags": [
                    "RZD API"
                ],
                "summary": "Получение маршрутов туда-обратно",
                "description": "Возвращает маршруты поездов туда и обратно между двумя точками.",
