                        }
                    },
                    {
                        "name": "code1",
                        "in": "query",
                        "description": "Код станции прибытия",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "dir",
                        "in": "query",
                        "description": "Направление (0 - в одну сторону, 1 - туда-обратно)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "tfl",
                        "in": "query",
                        "description": "Тип поезда (3 - поезда и электрички, 2 - электрички, 1 - поезда)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 3
                        }
                    },
                    {
                        "name": "checkSeats",
                        "in": "query",
                        "description": "Проверка наличия свободных мест (1 - с билетами, 0 - все поезда)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "dt0",
                        "in": "query",
                        "description": "Дата отправления в формате d.m.Y",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "default": ""
                        }
                    },
                    {
                        "name": "dt1",
                        "in": "query",
                        "description": "Дата возврата в формате d.m.Y",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "default": ""
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список маршрутов туда и обратно",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "forward": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/TrainRoute"
                                            }
                                        },
                                        "back": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/TrainRoute"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Некорректные параметры запроса",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "error": {
                                            "type": "string",
                                            "example": "Некорректный код станции отправления"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
